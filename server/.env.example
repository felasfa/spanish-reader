# Copy this file to .env and fill in the values
# DO NOT commit .env to git

PORT=3000

# GitHub — token needs repo read+write access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=felasfa
GITHUB_REPO=spanish-reader
GITHUB_DATA_BRANCH=main

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Gmail IMAP (use an App Password, not your real password)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# CORS — comma-separated list of allowed origins (in addition to localhost)
# Example: https://myapp.netlify.app,https://felasfa.app
CORS_ORIGINS=
